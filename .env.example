# MTB School & College — Environment Variables
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=your-very-secret-key-here-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Database (default: SQLite in instance/)
# DATABASE_URL=sqlite:///mtb_school.db
# DATABASE_URL=postgresql://user:password@localhost/mtb_school

# School Info
SCHOOL_NAME=MTB School & College

# File Uploads
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=5242880

# Security
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
PERMANENT_SESSION_LIFETIME=86400

# Face Recognition (optional)
FACE_RECOGNITION_TOLERANCE=0.6
FACE_RECOGNITION_SAMPLES=5

# Email (optional — for notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
